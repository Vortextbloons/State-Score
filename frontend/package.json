{
	"name": "statescore-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n fe,be -c blue,green \"vite dev\" \"cd .. && cross-env STATESCORE_PORT=8080 STATESCORE_NO_BROWSER=1 air\"",
		"dev:backend": "cd .. && cross-env STATESCORE_PORT=8080 STATESCORE_NO_BROWSER=1 air",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^26.1.1",
		"@typescript/native": "npm:typescript@^7.0.2",
		"@vitest/browser-playwright": "^4.1.10",
		"concurrently": "^10.0.3",
		"cross-env": "^10.1.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"typescript": "npm:@typescript/typescript6@^6.0.2",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^3.0.0"
	},
	"dependencies": {
		"layerchart": "^2.0.1"
	}
}
