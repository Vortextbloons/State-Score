{
	"name": "statescore",
	"private": true,
	"scripts": {
		"dev": "concurrently -n fe,be -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
		"dev:frontend": "npm run dev --prefix frontend",
		"dev:backend": "cross-env STATESCORE_PORT=8080 STATESCORE_NO_BROWSER=1 go run ./cmd/statescore",
		"build": "npm run build --prefix frontend",
		"check": "npm run check --prefix frontend",
		"test": "npm test --prefix frontend",
		"lint": "npm run lint --prefix frontend",
		"combine-docs": "node scripts/combine-docs.mjs",
		"update-rankings": "node scripts/update-rankings.mjs"
	},
	"devDependencies": {
		"concurrently": "^10.0.3",
		"cross-env": "^10.1.0"
	}
}
